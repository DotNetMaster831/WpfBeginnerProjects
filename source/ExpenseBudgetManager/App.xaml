<Application x:Class="ExpenseBudgetManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ExpenseBudgetManager"
             xmlns:vm="clr-namespace:ExpenseBudgetManager.ViewModels"
             xmlns:v="clr-namespace:ExpenseBudgetManager.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- MaterialDesign (must be first) -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml"/>

                <!-- Our custom resources (order matters) -->
                <ResourceDictionary Source="Resources/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
                <ResourceDictionary Source="Resources/DataTemplates.xaml"/>

            </ResourceDictionary.MergedDictionaries>


            <!-- ViewModel → View wiring -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <v:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TransactionViewModel}">
                <v:TransactionView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:BudgetViewModel}">
                <v:BudgetView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <v:SettingsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
