<Application x:Class="ExpenseBudgetManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ExpenseBudgetManager"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══ Brand Palette ═══ -->
            <Color x:Key="HunterGreenColor"   >#386641</Color>
            <Color x:Key="SageGreenColor"     >#6A994E</Color>
            <Color x:Key="YellowGreenColor"   >#A7C957</Color>
            <Color x:Key="VanillaCreamColor"  >#F2E8CF</Color>
            <Color x:Key="BlushedBrickColor"  >#BC4749</Color>

            <!-- ═══ Semantic Brushes ═══ -->
            <SolidColorBrush x:Key="AppBgBrush"         Color="#1A2E1A"/>
            <SolidColorBrush x:Key="SidebarBgBrush"     Color="#386641"/>
            <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#6A994E"/>
            <SolidColorBrush x:Key="PrimaryBtnBrush"    Color="#6A994E"/>
            <SolidColorBrush x:Key="PrimaryBtnHoverBrush" Color="#A7C957"/>
            <SolidColorBrush x:Key="AccentBrush"        Color="#A7C957"/>
            <SolidColorBrush x:Key="CardBgBrush"        Color="#243324"/>
            <SolidColorBrush x:Key="CardBorderBrush"    Color="#386641"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#F2E8CF"/>
            <SolidColorBrush x:Key="TextMutedBrush"     Color="#B8C9A3"/>
            <SolidColorBrush x:Key="IncomeBrush"        Color="#6A994E"/>
            <SolidColorBrush x:Key="ExpenseBrush"       Color="#BC4749"/>
            <SolidColorBrush x:Key="DangerBrush"        Color="#BC4749"/>
            <SolidColorBrush x:Key="InputBgBrush"       Color="#243324"/>
            <SolidColorBrush x:Key="InputBorderBrush"   Color="#6A994E"/>
            <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#243324"/>
            <SolidColorBrush x:Key="DataGridHoverBrush" Color="#2D4A2D"/>
            <SolidColorBrush x:Key="StatusBarBrush"     Color="#386641"/>
            <SolidColorBrush x:Key="BorderBrush"        Color="#386641"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
