<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:models="clr-namespace:ExpenseBudgetManager.Models">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml"/>
        <ResourceDictionary Source="Styles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════ -->
    <!--     TRANSACTION ROW TEMPLATE            -->
    <!-- Used in Dashboard recent list           -->
    <!-- ═══════════════════════════════════════ -->
    <DataTemplate x:Key="TransactionRowTemplate"
                  DataType="{x:Type models:Transaction}">
        <Border Padding="14,10"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <!-- Icon -->
                    <ColumnDefinition Width="*"/>
                    <!-- Title + Category -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Amount -->
                    <ColumnDefinition Width="90"/>
                    <!-- Date -->
                </Grid.ColumnDefinitions>

                <!-- Type icon -->
                <Border Grid.Column="0"
                        Width="32" Height="32"
                        CornerRadius="16"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="{StaticResource CardHoverBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Type}"
                                             Value="Income">
                                    <Setter Property="Background"
                                            Value="#1E3D1E"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}"
                                             Value="Expense">
                                    <Setter Property="Background"
                                            Value="#3D1E1E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <md:PackIcon x:Name="TypeIcon"
                                 Kind="ArrowDownBold"
                                 Width="16" Height="16"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="{StaticResource IncomeBrush}"/>
                </Border>

                <!-- Title and category -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="10,0">
                    <TextBlock Text="{Binding Title}"
                               FontSize="{StaticResource FontSizeNormal}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Category}"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Amount — green for income, red for expense -->
                <TextBlock Grid.Column="2"
                           Text="{Binding AmountDisplay}"
                           FontWeight="Bold"
                           FontSize="{StaticResource FontSizeNormal}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground"
                                    Value="{StaticResource IncomeBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Type}"
                                             Value="Expense">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource ExpenseBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Date -->
                <TextBlock Grid.Column="3"
                           Text="{Binding Date, StringFormat='dd MMM yyyy'}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>

            <!-- Trigger to swap arrow direction -->
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Type}" Value="Expense">
                            <Setter Property="Tag" Value="Expense"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
    </DataTemplate>

    <!-- ═══════════════════════════════════════ -->
    <!--     SUMMARY CARD TEMPLATE               -->
    <!-- Used in Dashboard for totals            -->
    <!-- ═══════════════════════════════════════ -->
    <DataTemplate x:Key="SummaryCardTemplate">
        <Border Style="{StaticResource CardStyle}"
                MinWidth="160">
            <StackPanel>
                <TextBlock Text="{Binding Label}"
                           Style="{StaticResource LabelTextStyle}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="{Binding Amount}"
                           FontSize="{StaticResource FontSizeLarge}"
                           FontWeight="Bold"
                           Foreground="{Binding AmountColor}"/>
                <TextBlock Text="{Binding SubText}"
                           Style="{StaticResource MutedTextStyle}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!-- ═══════════════════════════════════════ -->
    <!--     NAVIGATION ITEM TEMPLATE            -->
    <!-- Used in Sidebar ListBox                 -->
    <!-- ═══════════════════════════════════════ -->
    <DataTemplate x:Key="NavItemTemplate">
        <StackPanel Orientation="Horizontal" Margin="4,2">
            <md:PackIcon Kind="{Binding IconKind}"
                         Width="18" Height="18"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"
                         Foreground="{StaticResource SidebarTextBrush}"/>
            <TextBlock Text="{Binding Label}"
                       FontSize="{StaticResource FontSizeNormal}"
                       Foreground="{StaticResource SidebarTextBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>