<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ═══════════════════════════════════════ -->
    <!--           RAW COLOR VALUES              -->
    <!-- ═══════════════════════════════════════ -->
    <Color x:Key="HunterGreenColor"  >#386641</Color>
    <Color x:Key="SageGreenColor"    >#6A994E</Color>
    <Color x:Key="YellowGreenColor"  >#A7C957</Color>
    <Color x:Key="VanillaCreamColor" >#F2E8CF</Color>
    <Color x:Key="BlushedBrickColor" >#BC4749</Color>

    <!-- Derived darks -->
    <Color x:Key="AppBgColor"        >#1A2E1A</Color>
    <Color x:Key="CardBgColor"       >#243324</Color>
    <Color x:Key="CardHoverColor"    >#2D4A2D</Color>
    <Color x:Key="InputBgColor"      >#1E3A1E</Color>
    <Color x:Key="DividerColor"      >#2E5230</Color>
    <Color x:Key="OverlayColor"      >#0D1F0D</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor"  >#F2E8CF</Color>
    <Color x:Key="TextMutedColor"    >#B8C9A3</Color>
    <Color x:Key="TextDisabledColor" >#7A8C6A</Color>

    <!-- ═══════════════════════════════════════ -->
    <!--           SEMANTIC BRUSHES              -->
    <!-- ═══════════════════════════════════════ -->

    <!-- Layout -->
    <SolidColorBrush x:Key="AppBgBrush"          Color="{StaticResource AppBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush"         Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="CardHoverBrush"      Color="{StaticResource CardHoverColor}"/>
    <SolidColorBrush x:Key="OverlayBrush"        Color="{StaticResource OverlayColor}"/>
    <SolidColorBrush x:Key="DividerBrush"        Color="{StaticResource DividerColor}"/>

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBgBrush"      Color="{StaticResource HunterGreenColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush"   Color="#2E5230"/>
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="{StaticResource SageGreenColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush"    Color="{StaticResource VanillaCreamColor}"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="PrimaryBtnBrush"     Color="{StaticResource SageGreenColor}"/>
    <SolidColorBrush x:Key="PrimaryBtnHoverBrush" Color="{StaticResource YellowGreenColor}"/>
    <SolidColorBrush x:Key="PrimaryBtnFgBrush"   Color="{StaticResource AppBgColor}"/>
    <SolidColorBrush x:Key="DangerBtnBrush"      Color="{StaticResource BlushedBrickColor}"/>
    <SolidColorBrush x:Key="DangerBtnHoverBrush" Color="#D45558"/>
    <SolidColorBrush x:Key="GhostBtnBrush"       Color="Transparent"/>
    <SolidColorBrush x:Key="GhostBtnHoverBrush"  Color="#2E5230"/>

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBgBrush"        Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="InputBorderBrush"    Color="{StaticResource SageGreenColor}"/>
    <SolidColorBrush x:Key="InputFocusBrush"     Color="{StaticResource YellowGreenColor}"/>
    <SolidColorBrush x:Key="InputErrorBrush"     Color="{StaticResource BlushedBrickColor}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush"    Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"      Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush"   Color="{StaticResource TextDisabledColor}"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="IncomeBrush"         Color="{StaticResource SageGreenColor}"/>
    <SolidColorBrush x:Key="ExpenseBrush"        Color="{StaticResource BlushedBrickColor}"/>
    <SolidColorBrush x:Key="AccentBrush"         Color="{StaticResource YellowGreenColor}"/>
    <SolidColorBrush x:Key="DangerBrush"         Color="{StaticResource BlushedBrickColor}"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="#E9C46A"/>
    <SolidColorBrush x:Key="SuccessBrush"        Color="{StaticResource SageGreenColor}"/>

    <!-- DataGrid -->
    <SolidColorBrush x:Key="GridHeaderBrush"     Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="GridRowHoverBrush"   Color="{StaticResource CardHoverColor}"/>
    <SolidColorBrush x:Key="GridLineBrush"       Color="{StaticResource DividerColor}"/>
    <SolidColorBrush x:Key="GridSelectedBrush"   Color="#3A5C3A"/>

    <!-- Status bar -->
    <SolidColorBrush x:Key="StatusBarBrush"      Color="{StaticResource HunterGreenColor}"/>

    <!-- ═══════════════════════════════════════ -->
    <!--         CORNER RADIUS VALUES            -->
    <!-- ═══════════════════════════════════════ -->
    <CornerRadius x:Key="SmallRadius"  >4</CornerRadius>
    <CornerRadius x:Key="MediumRadius" >8</CornerRadius>
    <CornerRadius x:Key="LargeRadius"  >12</CornerRadius>
    <CornerRadius x:Key="PillRadius"   >20</CornerRadius>

    <!-- ═══════════════════════════════════════ -->
    <!--           FONT SIZES                    -->
    <!-- ═══════════════════════════════════════ -->
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib"
                   x:Key="FontSizeSmall">11</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib"
                   x:Key="FontSizeNormal">13</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib"
                   x:Key="FontSizeMedium">15</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib"
                   x:Key="FontSizeLarge">18</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib"
                   x:Key="FontSizeTitle">24</System:Double>

</ResourceDictionary>