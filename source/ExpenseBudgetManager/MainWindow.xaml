<Window x:Class="ExpenseBudgetManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:ExpenseBudgetManager"
        xmlns:vm="clr-namespace:ExpenseBudgetManager.ViewModels"
        xmlns:v="clr-namespace:ExpenseBudgetManager.Views"
        mc:Ignorable="d"
        Title="Expense Budget Manager" 
        Height="700" 
        Width="1000"
        MinHeight="540"
        MinWidth="740"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBgBrush}"
        FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- Main area -->
            <RowDefinition Height="36"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <!-- Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Content -->
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!--                SIDEBAR                  -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{StaticResource SidebarBgBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- App branding -->
                <Border DockPanel.Dock="Top"
                        Padding="20,24,20,20"
                        BorderBrush="{StaticResource SidebarHoverBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="38" Height="38"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="10">
                            <md:PackIcon Kind="CurrencyUsd"
                                         Width="22" Height="22"
                                         Foreground="{StaticResource AppBgBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Expense"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Budget Manager"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav section label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="MENU"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="20,16,20,8"/>

                <!-- Nav items -->
                <ListBox DockPanel.Dock="Top"
                         ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="10,0">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Margin="4,2">
                                <md:PackIcon Kind="{Binding IconKind}"
                                             Width="18" Height="18"
                                             VerticalAlignment="Center"
                                             Foreground="{StaticResource SidebarTextBrush}"/>
                                <TextBlock Text="{Binding Label}"
                                           FontSize="14"
                                           Foreground="{StaticResource SidebarTextBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"  Value="0"/>
                            <Setter Property="Margin"   Value="0,2"/>
                            <Setter Property="Cursor"   Value="Hand"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                CornerRadius="{StaticResource MediumRadius}"
                                                Padding="12,10">
                                            <Grid>
                                                <!-- Left accent bar -->
                                                <Border x:Name="Accent"
                                                        Width="3" Height="18"
                                                        Background="{StaticResource AccentBrush}"
                                                        CornerRadius="2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Visibility="Collapsed"
                                                        Margin="-4,0,0,0"/>
                                                <ContentPresenter Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd"
                                                        Property="Background"
                                                        Value="{StaticResource SidebarSelectedBrush}"/>
                                                <Setter TargetName="Accent"
                                                        Property="Visibility"
                                                        Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd"
                                                        Property="Background"
                                                        Value="{StaticResource SidebarHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!--              CONTENT AREA               -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.Column="1"
                Background="{StaticResource AppBgBrush}"
                Padding="28">
            <Grid>

                <!-- Page header -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Page title bar -->
                    <RowDefinition Height="16"/>
                    <!-- Spacer -->
                    <RowDefinition Height="*"/>
                    <!-- Content -->
                </Grid.RowDefinitions>

                <!-- Page title bar -->
                <DockPanel Grid.Row="0">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{Binding SelectedNavItem.Label}"
                                   Style="{StaticResource SubtitleTextStyle}"
                                   FontSize="20"/>
                        <TextBlock Text="{Binding MonthText}"
                                   Style="{StaticResource MutedTextStyle}"
                                   FontSize="12"/>
                    </StackPanel>

                    <!-- Right side — search hint -->
                    <Border DockPanel.Dock="Right"
                            Background="{StaticResource CardBgBrush}"
                            CornerRadius="{StaticResource MediumRadius}"
                            Padding="12,7"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Magnify"
                                         Width="16" Height="16"
                                         Foreground="{StaticResource TextMutedBrush}"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="Search transactions..."
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DockPanel>

                <!-- Divider -->
                <Border Grid.Row="1"
                        Height="1"
                        Background="{StaticResource DividerBrush}"
                        Margin="0,8"/>

                <!-- Animated content area -->
                <ContentControl x:Name="MainContent"
                                Grid.Row="2"
                                Content="{Binding CurrentView}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="0" To="1"
                                                Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════ -->
        <!--              STATUS BAR                 -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="0"
        Grid.ColumnSpan="2"
        Background="{StaticResource StatusBarBrush}"
        BorderBrush="{StaticResource DividerBrush}"
        BorderThickness="0,1,0,0">
            <DockPanel Margin="16,0">

                <!-- LEFT — balance -->
                <StackPanel DockPanel.Dock="Left"
                    Orientation="Horizontal">
                    <md:PackIcon Kind="Wallet"
                         Width="14" Height="14"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         VerticalAlignment="Center"/>
                    <TextBlock Text="Balance:"
                       FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding BalanceText}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Separator -->
                <TextBlock DockPanel.Dock="Left"
                   Text="·"
                   Foreground="{StaticResource TextMutedBrush}"
                   Margin="10,0" VerticalAlignment="Center"/>

                <!-- Month -->
                <TextBlock DockPanel.Dock="Left"
                   Text="{Binding MonthText}"
                   FontSize="12"
                   Foreground="{StaticResource TextMutedBrush}"
                   VerticalAlignment="Center"/>

                <!-- Separator -->
                <TextBlock DockPanel.Dock="Left"
                   Text="·"
                   Foreground="{StaticResource TextMutedBrush}"
                   Margin="10,0" VerticalAlignment="Center"/>

                <!-- Current view -->
                <TextBlock DockPanel.Dock="Left"
                   Text="{Binding SelectedNavItem.Label,
                          StringFormat='Viewing: {0}'}"
                   FontSize="12"
                   Foreground="{StaticResource TextMutedBrush}"
                   VerticalAlignment="Center"/>

                <!-- RIGHT — version (docked last so it goes far right) -->
                <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <md:PackIcon Kind="About"
                         Width="13" Height="13"
                         Foreground="{StaticResource TextMutedBrush}"
                         VerticalAlignment="Center"/>
                    <TextBlock Text=" Expense Budget Manager v1.0.0"
                       FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
                </StackPanel>

            </DockPanel>
        </Border>

    </Grid>
</Window>
